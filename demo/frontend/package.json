{
  "name": "vldb-demo-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "start:e2e": "PORT=5174 VITE_API_TARGET=http://localhost:8001 concurrently -k -n be,fe -c blue,green \"cd ../.. && DEMO_E2E=1 poetry run uvicorn main:app --app-dir demo/backend --port 8001\" \"vite\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@tanstack/react-query": "^5.17.0",
    "@tanstack/react-virtual": "^3.0.1",
    "@types/cytoscape": "^3.21.9",
    "cytoscape": "^3.33.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "shiki": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.58.1",
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^14.1.2",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^9.2.1",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jsdom": "^23.2.0",
    "postcss": "^8.4.33",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.1",
    "typescript": "~5.3.3",
    "typescript-eslint": "^8.18.0",
    "vite": "^5.0.12",
    "vitest": "^1.2.2"
  }
}
